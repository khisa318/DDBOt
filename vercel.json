{
    "version": 2,
    "outputDirectory": "dist",
    "buildCommand": "npm run build",
    "installCommand": "npm install --legacy-peer-deps",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/static/(.*)",
            "destination": "/static/$1"
        },
        {
            "source": "/js/(.*)",
            "destination": "/js/$1"
        },
        {
            "source": "/assets/(.*)",
            "destination": "/assets/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
